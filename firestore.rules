rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: students
    // Fields: uid, hoTen, ngaySinh, gioiTinh, noiSinh, cccd, noiO, sdt, to, chucVu, stickerCount, role
    //
    // Collection: logs_general
    // Fields: date, hocTap, phongTrao, luuY, tamSu, thongBaoChung, ghiChepViecTot, ghiChepViPham, createdBy
    //
    // Collection: logs_group
    // Fields: date, to, tenHocSinh, hocTap, hoatDong, hoaDong, chuyenCan, dongPhuc, nhanRieng, createdBy
    //
    // Collection: logs_personal
    // Fields: date, uid, tenHocSinh, diemHT, diemHD, diemHoaDong, diemCC, diemDP, machRieng, mucDoHanhPhuc, canGapCo
    //
    // Collection: teacher_feedback
    // Fields: date, studentUid, noiDung, loaiSticker, stickerIcon
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/students/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (getUserData().role == 'teacher' || 
         (request.auth.token.email == "Dungta.hvn@gmail.com" && request.auth.token.email_verified == true));
    }

    function isClassLeader() {
      return isAuthenticated() && getUserData().role == 'class_leader';
    }

    function isGroupLeader() {
      return isAuthenticated() && getUserData().role == 'group_leader';
    }

    // Students collection
    match /students/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if isOwner(userId) || isAdmin();
    }

    // Logs General
    match /logs_general/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isClassLeader();
      allow update: if isAdmin() || isClassLeader();
    }

    // Logs Group
    match /logs_group/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isGroupLeader();
      allow update: if isAdmin() || isGroupLeader();
    }

    // Logs Personal
    match /logs_personal/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid;
    }

    // Teacher Feedback
    match /teacher_feedback/{feedbackId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
